msgctxt "UITextData/DOF_Description"
msgid ""
"Adds camera-style focus blur to objects based on distance. Makes scenes feel "
"more cinematic but has a small performance cost.\n"
"\n"
"<Bold>OFF</>:  No depth blur. Everything stays fully sharp.\n"
"\n"
"<Bold>ON</>:  Enables depth-based blur for a more film-like look, with "
"slight GPU usage."
msgstr ""

msgctxt "UITextData/Gamma_Description"
msgid ""
"Adjusts overall screen brightness. Higher gamma lifts dark areas; lower "
"gamma makes shadows deeper and the image more contrasty.\n"
"\n"
"Use the slider to tune visibility to your preference or your display."
msgstr ""

