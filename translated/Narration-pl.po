msgstr ""

msgctxt "NarrationTextData/BS_END_Stage1_Pt2_Lines_Index1_Line"
msgid "Yes the one with the doors, remember that??"
msgstr ""

msgctxt "NarrationTextData/WW_ROTSpill_Pt2_Lines_Index0_Line"
